---
const { title } = Astro.props;
---

<div id="topbar-wrapper">
  <div id="topbar">
    <span id="breadcrumb">
      <span><a href="/">Home</a></span>
      <span>{title}</span>
    </span>

    <i id="sidebar-trigger"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 448 512" width="1em" height="1em" fill="currentColor"><path d="M0 96C0 78.3 14.3 64 32 64h384c17.7 0 32 14.3 32 32s-14.3 32-32 32H32C14.3 128 0 113.7 0 96zm0 160c0-17.7 14.3-32 32-32h384c17.7 0 32 14.3 32 32s-14.3 32-32 32H32c-17.7 0-32-14.3-32-32zm448 160c0 17.7-14.3 32-32 32H32c-17.7 0-32-14.3-32-32s14.3-32 32-32h384c17.7 0 32 14.3 32 32z"/></svg></i>
    <div id="topbar-title">{title}</div>
    <i id="search-trigger"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" width="1em" height="1em" fill="currentColor"><path d="M416 208c0 45.9-14.9 88.3-40 122.7l126.6 126.7c12.5 12.5 12.5 32.8 0 45.3s-32.8 12.5-45.3 0L330.7 376c-34.4 25.2-76.8 40-122.7 40C93.1 416 0 322.9 0 208S93.1 0 208 0s208 93.1 208 208zM208 352a144 144 0 1 0 0-288 144 144 0 1 0 0 288z"/></svg></i>

    <span id="search-wrapper">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" width="1em" height="1em" fill="currentColor" class="search-icon"><path d="M416 208c0 45.9-14.9 88.3-40 122.7l126.6 126.7c12.5 12.5 12.5 32.8 0 45.3s-32.8 12.5-45.3 0L330.7 376c-34.4 25.2-76.8 40-122.7 40C93.1 416 0 322.9 0 208S93.1 0 208 0s208 93.1 208 208zM208 352a144 144 0 1 0 0-288 144 144 0 1 0 0 288z"/></svg>
      <input id="search-input" type="search" placeholder="Search..." />
      <div id="search-results"></div>
    </span>
  </div>
</div>

<script>
  import { fetchSearchData, searchPosts, renderResultItem } from '../scripts/search';
  import { MAX_SEARCH_DROPDOWN } from '../constants';
  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  const searchResults = document.getElementById('search-results')!;

  searchInput.addEventListener('focus', () => {
    fetchSearchData();
  });

  searchInput.addEventListener('input', async (e) => {
    const query = (e.target as HTMLInputElement).value;
    if (!query.trim()) {
      searchResults.innerHTML = '';
      searchResults.style.display = 'none';
      return;
    }

    const data = await fetchSearchData();
    const results = searchPosts(data, query);

    if (results.length === 0) {
      searchResults.innerHTML = '<div class="search-no-result">검색 결과가 없습니다</div>';
    } else {
      const items = results.slice(0, MAX_SEARCH_DROPDOWN).map(renderResultItem).join('');
      const more = results.length > MAX_SEARCH_DROPDOWN
        ? `<a class="search-more" href="/search?q=${encodeURIComponent(query)}">더 보기 (${results.length}건) →</a>`
        : '';
      searchResults.innerHTML = items + more;
    }
    searchResults.style.display = 'block';
  });

  document.addEventListener('click', (e) => {
    if (!(e.target as HTMLElement).closest('#search-wrapper')) {
      searchResults.style.display = 'none';
    }
  });
</script>
