---
interface Props {
  class?: string;
  rowAlign?: string;
  columnAlign?: string;
  reverse?: boolean;
}

const {
  class: className = '',
  rowAlign = 'flex-start',
  columnAlign = 'flex-start',
  reverse = false,
} = Astro.props;
---

<div
  class={`flex ${className}`}
  style={{
    flexDirection: reverse ? 'column-reverse' : 'column',
    justifyContent: columnAlign,
    alignItems: rowAlign,
  }}
>
  <slot />
</div>
