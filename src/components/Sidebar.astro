---
const navLinks = [
  { href: '/', label: '포스트' },
  { href: '/tags', label: '태그' },
  { href: '/categories', label: '카테고리' },
  { href: '/archives', label: '아카이브' },
];
---

<aside id="sidebar">
  <div class="profile-wrapper">
    <div id="avatar">
      <a href="/">
        <img src="/avatar.png" alt="avatar" />
      </a>
    </div>
    <div class="site-title">
      <a href="/">Hve</a>
    </div>
    <p class="site-subtitle">개발 블로그</p>
  </div>

  <ul>
    {navLinks.map(link => (
      <li class="nav-item">
        <a class="nav-link" href={link.href}>
          <span>{link.label}</span>
        </a>
      </li>
    ))}
  </ul>

  <div class="sidebar-bottom">
    <button id="theme-toggle" aria-label="테마 전환">🌙</button>
    <a href="https://github.com/hve4638" aria-label="GitHub">GitHub</a>
  </div>
</aside>
