---
import { getExcerpt } from '../utils/excerpt';

interface Props {
  post: {
    id: string;
    body?: string;
    data: {
      title: string;
      date: Date;
      categories?: string[];
      pin?: boolean;
    };
  };
}

const { post } = Astro.props;
---

<div class="post-preview">
  <a href={`/posts/${post.id}`}>
    <div class="card-body">
      <h1 class="card-title">{post.data.title}</h1>

      <div class="post-content">
        <p>{getExcerpt(post.body ?? '', 200)}</p>
      </div>

      <div class="post-meta">
        <div class="meta-left">
          <i class="far fa-calendar fa-fw"></i>
          <time datetime={post.data.date.toISOString()}>
            {`${post.data.date.getFullYear()}/${String(post.data.date.getMonth() + 1).padStart(2, '0')}/${String(post.data.date.getDate()).padStart(2, '0')}`}
          </time>
          {post.data.categories && post.data.categories.length > 0 && (
            <span class="categories">
              <i class="far fa-folder-open fa-fw"></i>
              {post.data.categories.join(", ")}
            </span>
          )}
        </div>
        {post.data.pin && (
          <div class="pin">
            <i class="fas fa-thumbtack fa-fw"></i>
          </div>
        )}
      </div>
    </div>
  </a>
</div>
