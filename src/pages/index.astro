---
import Base from "../layouts/Base.astro";
import { getCollection } from "astro:content";
import { getPage } from "../utils/pagination";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

const page = getPage(posts, 1);

function getExcerpt(body: string, length = 200) {
  const plain = body
    .replace(/```[\s\S]*?```/g, '')
    .replace(/!?\[.*?\]\(.*?\)/g, '')
    .replace(/[#*>`~_\-]/g, '')
    .replace(/\n+/g, ' ')
    .trim();
  return plain.length > length ? plain.slice(0, length) + '...' : plain;
}
---

<Base title="블로그">
  <div id="post-list">
    {page.data.map((post) => (
      <div class="post-preview">
        <a href={`/posts/${post.id}`}>
          <div class="card-body">
            <h1 class="card-title">{post.data.title}</h1>

            <div class="post-content">
              <p>{getExcerpt(post.body ?? '')}</p>
            </div>

            <div class="post-meta">
              <div class="meta-left">
                <time datetime={post.data.date.toISOString()}>
                  {post.data.date.toLocaleDateString("ko-KR")}
                </time>
                {post.data.categories && post.data.categories.length > 0 && (
                  <span class="categories">
                    {post.data.categories.join(", ")}
                  </span>
                )}
              </div>
              {post.data.pin && (
                <div class="pin">📌</div>
              )}
            </div>
          </div>
        </a>
      </div>
    ))}
  </div>

  <nav class="pagination">
    {page.prevUrl && (
      <a class="page-link" href={page.prevUrl}>&larr;</a>
    )}
    <span class="page-index">{page.currentPage} / {page.totalPages}</span>
    {page.nextUrl && (
      <a class="page-link" href={page.nextUrl}>&rarr;</a>
    )}
  </nav>
</Base>
