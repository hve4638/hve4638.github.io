---
import Base from '../../layouts/Base.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';

// [Astro] [...slug]: catch-all 동적 라우팅. 슬래시를 포함한 여러 세그먼트를 하나로 받는다.
// /categories/개발       → slug = "개발"
// /categories/개발/도구  → slug = "개발/도구"
// /categories/a/b/c     → slug = "a/b/c"
export async function getStaticPaths() {
  const posts = await getCollection('blog');

  // 모든 카테고리 경로를 수집 (각 깊이별로)
  // 예: categories: ["개발", "도구"] → 경로 2개 생성: "개발", "개발/도구"
  const pathMap = new Map<string, typeof posts>();

  for (const post of posts) {
    const cats = post.data.categories;
    // 각 깊이별 경로 생성
    for (let depth = 1; depth <= cats.length; depth++) {
      const path = cats.slice(0, depth).join('/');
      if (!pathMap.has(path)) pathMap.set(path, []);
      pathMap.get(path)!.push(post);
    }
  }

  return [...pathMap.entries()].map(([path, matchedPosts]) => ({
    params: { slug: path },
    props: {
      segments: path.split('/'),
      posts: matchedPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime()),
    },
  }));
}

const { segments, posts } = Astro.props;
const title = segments[segments.length - 1];
---

<Base title={`카테고리: ${title}`}>
  <div class="category-header">
    <h1 class="category-title">{title}</h1>
    <span class="category-count">{posts.length} posts</span>
  </div>

  <div id="post-list">
    {posts.map(post => (
      <PostCard post={post} />
    ))}
  </div>
</Base>

<style>
  .category-header {
    padding: 0 1rem;
    margin-bottom: 1rem;
  }

  .category-title {
    font-size: 1.8rem;
    font-weight: 600;
    color: var(--heading-color);
    margin: 0;
  }

  .category-count {
    font-size: 0.9rem;
    color: var(--text-muted-color);
  }
</style>
