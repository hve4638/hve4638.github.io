---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

// [Astro] paginate: getStaticPaths의 인자로 제공되는 내장 함수.
// 배열을 pageSize만큼 잘라서 페이지별 경로와 데이터를 자동 생성한다.
export async function getStaticPaths({ paginate }) {
  const posts = (await getCollection('blog'))
    .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

  return paginate(posts, { pageSize: 20 });
}

// [Astro] paginate()가 자동으로 넘겨주는 page 객체:
// page.data       — 현재 페이지의 포스트 배열
// page.currentPage — 현재 페이지 번호 (1부터)
// page.lastPage   — 마지막 페이지 번호
// page.url.prev   — 이전 페이지 URL (없으면 undefined)
// page.url.next   — 다음 페이지 URL (없으면 undefined)
const { page } = Astro.props;
---

<Base title="포스트 목록">
  <h1>포스트 목록</h1>
  <ul>
    {page.data.map(post => (
      <li>
        <time datetime={post.data.date.toISOString()}>
          {post.data.date.toLocaleDateString('ko-KR')}
        </time>
        {' - '}
        <a href={`/blog/${post.id}`}>{post.data.title}</a>
      </li>
    ))}
  </ul>

  {/* 페이지네이션 네비게이션 */}
  <nav>
    {page.url.prev && <a href={page.url.prev}>&larr; 이전</a>}
    <span> {page.currentPage} / {page.lastPage} </span>
    {page.url.next && <a href={page.url.next}>다음 &rarr;</a>}
  </nav>
</Base>
