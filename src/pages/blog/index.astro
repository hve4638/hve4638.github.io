---
import Base from '../../layouts/Base.astro';
// [Astro] getCollection: Content Collection에서 데이터를 가져오는 함수.
// Jekyll의 site.posts와 달리, 명시적 함수 호출로 콘텐츠를 조회한다.
import { getCollection } from 'astro:content';

// [Astro] 이 코드는 빌드 시점에 서버에서 실행된다. await를 최상위에서 쓸 수 있다 (top-level await).
const posts = (await getCollection('blog'))
  // [Astro] 정렬도 직접 코드로 명시. Jekyll은 date 기준 자동 정렬이지만, Astro는 직접 해야 한다.
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<!-- [Astro] --- 아래가 "템플릿 영역". HTML + JSX 스타일 표현식 -->
<Base title="포스트 목록">
  <h1>포스트 목록</h1>
  <ul>
    {/* [Astro] JSX의 .map()으로 반복 렌더링. Liquid의 {% for post in site.posts %}에 해당 */}
    {posts.map(post => (
      <li>
        <time datetime={post.data.date.toISOString()}>
          {post.data.date.toLocaleDateString('ko-KR')}
        </time>
        {' - '}
        {/* [Astro] post.id: 파일명(확장자 제외)이 곧 slug. 예: git-branch.md → "git-branch" */}
        <a href={`/blog/${post.id}`}>{post.data.title}</a>
      </li>
    ))}
  </ul>
</Base>
