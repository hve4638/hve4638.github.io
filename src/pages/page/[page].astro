---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { getPage, getPageNumbers } from '../../utils/pagination';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const pageNumbers = getPageNumbers(posts.length);

  return pageNumbers.map(num => ({
    params: { page: String(num) },
  }));
}

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const pageNum = Number(Astro.params.page);
const page = getPage(posts, pageNum);
---

<Base title={`포스트 목록 - ${page.currentPage}페이지`}>
  <h1>포스트 목록</h1>
  <ul>
    {page.data.map(post => (
      <li>
        <time datetime={post.data.date.toISOString()}>
          {post.data.date.toLocaleDateString('ko-KR')}
        </time>
        {' - '}
        <a href={`/posts/${post.id}`}>{post.data.title}</a>
      </li>
    ))}
  </ul>

  <nav>
    {page.prevUrl && <a href={page.prevUrl}>&larr; 이전</a>}
    <span> {page.currentPage} / {page.totalPages} </span>
    {page.nextUrl && <a href={page.nextUrl}>다음 &rarr;</a>}
  </nav>
</Base>
